{{! systems/mythras-imperative/templates/items/weapon-sheet.hbs }}
<div class="mi-item-sheet-body">

  {{! ── HEADER ─────────────────────────────────────────────────────────── }}
  <header class="mi-item-header">
    <img class="mi-item-img" src="{{item.img}}" data-edit="img" title="{{item.name}}"/>
    <div class="mi-item-title-block">
      <input class="mi-item-name" type="text" name="name" value="{{item.name}}"
             placeholder="Weapon name"/>
      <div class="mi-item-subtitle">
        {{#if isMelee}}
          <span class="mi-item-type-pill">Melee Weapon</span>
        {{else}}
          <span class="mi-item-type-pill">Ranged Weapon</span>
        {{/if}}
        <span class="mi-item-formula mi-muted">{{system.damage}}</span>
      </div>
    </div>
    <div class="mi-item-total-block">
      <div class="mi-item-total-num">{{system.ap}}/{{system.hp}}</div>
      <div class="mi-item-total-label">AP / HP</div>
    </div>
  </header>

  {{! ── ROW 1 — Category, Damage, Size/Force, Reach, Dmg Mod, Equipped ─── }}
  <div class="mi-item-stats">

    <div class="mi-stat-cell">
      <div class="mi-stat-label">Category</div>
      <select name="system.category" class="mi-stat-select">
        {{#select system.category}}
          <option value="melee">Melee</option>
          <option value="ranged">Ranged</option>
        {{/select}}
      </select>
    </div>

    <div class="mi-stat-cell">
      <div class="mi-stat-label">Damage</div>
      <input type="text" name="system.damage" value="{{system.damage}}"
             class="mi-stat-input" placeholder="1d6"/>
    </div>

    {{#if isMelee}}
    <div class="mi-stat-cell">
      <div class="mi-stat-label">Size</div>
      <select name="system.size" class="mi-stat-select">
        {{#select system.size}}
          <option value="S">S — Small</option>
          <option value="M">M — Medium</option>
          <option value="L">L — Large</option>
          <option value="H">H — Huge</option>
          <option value="E">E — Enormous</option>
        {{/select}}
      </select>
    </div>

    <div class="mi-stat-cell">
      <div class="mi-stat-label">Reach</div>
      <select name="system.reach" class="mi-stat-select">
        {{#select system.reach}}
          <option value="T">Touch</option>
          <option value="S">Short</option>
          <option value="M">Medium</option>
          <option value="L">Long</option>
          <option value="VL">Very Long</option>
        {{/select}}
      </select>
    </div>
    {{/if}}

    {{! Both melee and ranged show Dmg Mod Applies }}
    <div class="mi-stat-cell">
      <div class="mi-stat-label">Dmg Mod</div>
      <select name="system.damageModApplies" class="mi-stat-select">
        {{#select system.damageModApplies}}
          <option value="true">Yes</option>
          <option value="false">No</option>
        {{/select}}
      </select>
    </div>

    {{#if isRanged}}
    <div class="mi-stat-cell">
      <div class="mi-stat-label">Force</div>
      <select name="system.force" class="mi-stat-select">
        {{#select system.force}}
          <option value="S">S — Small</option>
          <option value="M">M — Medium</option>
          <option value="L">L — Large</option>
          <option value="H">H — Huge</option>
          <option value="E">E — Enormous</option>
        {{/select}}
      </select>
    </div>
    {{/if}}

    <div class="mi-stat-cell">
      <div class="mi-stat-label">Equipped</div>
      <input type="checkbox" name="system.equipped"
             {{#if system.equipped}}checked{{/if}} class="mi-stat-checkbox"/>
    </div>

  </div>

  {{! ── ROW 2 — Weapon AP, HP, Current HP, ENC ─────────────────────────── }}
  <div class="mi-item-stats">

    <div class="mi-stat-cell">
      <div class="mi-stat-label">Weapon AP</div>
      <input type="number" name="system.ap" value="{{system.ap}}"
             class="mi-stat-input mi-stat-input--num" min="0"/>
    </div>

    <div class="mi-stat-cell">
      <div class="mi-stat-label">Weapon HP</div>
      <input type="number" name="system.hp" value="{{system.hp}}"
             class="mi-stat-input mi-stat-input--num" min="0"/>
    </div>

    <div class="mi-stat-cell">
      <div class="mi-stat-label">Current HP</div>
      <input type="number" name="system.currentHP" value="{{system.currentHP}}"
             class="mi-stat-input mi-stat-input--num"/>
    </div>

    <div class="mi-stat-cell">
      <div class="mi-stat-label">ENC</div>
      <input type="number" name="system.enc" value="{{system.enc}}"
             class="mi-stat-input mi-stat-input--num" min="0" step="0.5"/>
    </div>

  </div>

  {{! ── ROW 3 — Ranged-only: Range bands, Load, Impale Size ─────────────── }}
  {{#if isRanged}}
  <div class="mi-item-stats mi-item-stats--ranged">

    <div class="mi-stat-cell">
      <div class="mi-stat-label">Close (m)</div>
      <input type="number" name="system.rangeClose" value="{{system.rangeClose}}"
             class="mi-stat-input mi-stat-input--num" min="0"/>
    </div>

    <div class="mi-stat-cell">
      <div class="mi-stat-label">Effective (m)</div>
      <input type="number" name="system.rangeEffective" value="{{system.rangeEffective}}"
             class="mi-stat-input mi-stat-input--num" min="0"/>
    </div>

    <div class="mi-stat-cell">
      <div class="mi-stat-label">Long (m)</div>
      <input type="number" name="system.rangeLong" value="{{system.rangeLong}}"
             class="mi-stat-input mi-stat-input--num" min="0"/>
    </div>

    {{! Extreme band — firearms only }}
    {{#if isFirearm}}
    <div class="mi-stat-cell">
      <div class="mi-stat-label">Extreme (m)</div>
      <input type="number" name="system.rangeExtreme" value="{{system.rangeExtreme}}"
             class="mi-stat-input mi-stat-input--num" min="0"/>
    </div>
    {{/if}}

    <div class="mi-stat-cell">
      <div class="mi-stat-label">Load (turns)</div>
      <input type="number" name="system.load" value="{{system.load}}"
             class="mi-stat-input mi-stat-input--num" min="0"/>
    </div>

    <div class="mi-stat-cell">
      <div class="mi-stat-label">Impale Size</div>
      <select name="system.impaleSize" class="mi-stat-select">
        {{#select system.impaleSize}}
          <option value="S">S — Small</option>
          <option value="M">M — Medium</option>
          <option value="L">L — Large</option>
          <option value="H">H — Huge</option>
          <option value="E">E — Enormous</option>
        {{/select}}
      </select>
    </div>

  </div>

  {{! ── ROW 4 — Ranged-only: Ammo ──────────────────────────────────────── }}
  <div class="mi-item-stats mi-item-stats--ranged">

    <div class="mi-stat-cell">
      <div class="mi-stat-label">Ammo (loaded)</div>
      <input type="number" name="system.ammo" value="{{system.ammo}}"
             class="mi-stat-input mi-stat-input--num" min="0"/>
    </div>

    <div class="mi-stat-cell">
      <div class="mi-stat-label">Ammo (max)</div>
      <input type="number" name="system.ammoMax" value="{{system.ammoMax}}"
             class="mi-stat-input mi-stat-input--num" min="0"/>
    </div>

    <div class="mi-stat-cell mi-stat-cell--reload">
      <div class="mi-stat-label">&nbsp;</div>
      <a class="mi-reload-btn mi-reload-btn--sheet" title="Reload to max"><i class="fas fa-redo"></i> Reload</a>
      {{#if isJammed}}
      <a class="mi-clear-jam-btn mi-clear-jam-btn--sheet" title="Field-strip: clear jam (costs 1 AP in combat)"><i class="fas fa-exclamation-triangle"></i> JAM <i class="fas fa-wrench"></i></a>
      {{/if}}
    </div>

  </div>

  {{! ── ROW 4b — Ranged-only: Loaded Ammo pill ─────────────────────────── }}
  <div class="mi-item-stats mi-item-stats--ranged">
    <div class="mi-stat-cell mi-stat-cell--full">
      <div class="mi-stat-label">Loaded Ammo <span class="mi-section-hint">— drag an ammo item here to load</span></div>
      {{#if loadedAmmo}}
        <div class="mi-loaded-ammo-pill">
          <i class="fas fa-arrow-alt-circle-right"></i>
          <span class="mi-loaded-ammo-name">{{loadedAmmo.name}}</span>
          <button class="mi-clear-ammo-btn" type="button" title="Unload ammo">×</button>
        </div>
      {{else}}
        <div class="mi-drop-hint mi-drop-hint--inline">
          <i class="fas fa-arrow-down"></i> No ammo loaded — drag an ammo item here
        </div>
      {{/if}}
    </div>
  </div>

  {{! ── ROW 5 — Firearms only: Firing Mode, Burst Size, Cyclic Rate ──────── }}
  {{#if isFirearm}}
  <div class="mi-item-stats mi-item-stats--ranged">

    <div class="mi-stat-cell">
      <div class="mi-stat-label">Firing Mode</div>
      <select name="system.firingMode" class="mi-stat-select">
        {{#select system.firingMode}}
          <option value="single">Single</option>
          <option value="burst">Burst</option>
          <option value="fullAuto">Full Auto</option>
        {{/select}}
      </select>
    </div>

    <div class="mi-stat-cell">
      <div class="mi-stat-label">Burst Size</div>
      <input type="number" name="system.burstSize" value="{{system.burstSize}}"
             class="mi-stat-input mi-stat-input--num" min="0"/>
    </div>

    <div class="mi-stat-cell">
      <div class="mi-stat-label">Cyclic Rate</div>
      <input type="number" name="system.cyclicRate" value="{{system.cyclicRate}}"
             class="mi-stat-input mi-stat-input--num" min="0"/>
    </div>

  </div>
  {{/if}}

  {{/if}}

  {{! ── TRAITS ──────────────────────────────────────────────────────────── }}
  <div class="mi-weapon-traits-block">
    <div class="mi-section-label mi-section-label--teal">Traits</div>
    <div class="mi-traits-grid">
      {{#each traitOptions as |trait|}}
      <label class="mi-trait-option {{#if trait.checked}}active{{/if}}"
             title="{{trait.description}}">
        <input type="checkbox" class="mi-trait-cb" value="{{trait.key}}"
               {{#if trait.checked}}checked{{/if}}/>
        {{trait.label}}
      </label>
      {{/each}}
    </div>
  </div>

  {{! ── DESCRIPTION ─────────────────────────────────────────────────────── }}
  {{! ── PRICE ───────────────────────────────────────────────────────────── }}
  <div class="mi-item-price-row">
    <div class="mi-section-label">Price</div>
    <div class="mi-price-inputs">
      <input class="mi-price-amount" type="number" name="system.price.amount"
             value="{{system.price.amount}}" min="0" step="1"
             placeholder="0" title="Cost in the listed denomination"/>
      <input class="mi-price-denom" type="text" name="system.price.denominationAbbr"
             value="{{system.price.denominationAbbr}}"
             placeholder="GP" title="Currency abbreviation (e.g. GP, SP, Cr)"/>
    </div>
  </div>

  <div class="mi-item-desc-block">
    <div class="mi-section-label">Description</div>
    <textarea name="system.description" class="mi-item-desc"
              placeholder="Weapon notes…">{{system.description}}</textarea>
  </div>

</div>
