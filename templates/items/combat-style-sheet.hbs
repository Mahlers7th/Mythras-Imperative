{{! systems/mythras-imperative/templates/items/combat-style-sheet.hbs }}
<div class="mi-item-sheet-body mi-cs-sheet-body">

  {{! ── HEADER ─────────────────────────────────────────────────────────── }}
  <header class="mi-item-header">
    <img class="mi-item-img" src="{{item.img}}" data-edit="img" title="{{item.name}}"/>
    <div class="mi-item-title-block">
      <input class="mi-item-name" type="text" name="name" value="{{item.name}}" placeholder="Combat Style name"/>
      <div class="mi-item-subtitle">
        <span class="mi-item-type-pill">Combat Style</span>
        <span class="mi-item-formula mi-muted">{{system.baseFormula}}</span>
      </div>
    </div>
    <div class="mi-item-total-block">
      <div class="mi-item-total-num">{{liveTotal}}%</div>
      <div class="mi-item-total-label">Total</div>
    </div>
  </header>

  {{! ── STATS ROW ───────────────────────────────────────────────────────── }}
  <div class="mi-item-stats">
    <div class="mi-stat-cell">
      <div class="mi-stat-label">Base Formula</div>
      <input type="text" name="system.baseFormula" value="{{system.baseFormula}}"
             class="mi-stat-input" placeholder="STR+DEX"/>
    </div>
    <div class="mi-stat-cell">
      <div class="mi-stat-label">Base Value</div>
      <div class="mi-stat-value mi-muted">{{liveBase}}</div>
    </div>
    <div class="mi-stat-cell">
      <div class="mi-stat-label">Bonus Pts</div>
      <input type="number" name="system.bonusPoints" value="{{system.bonusPoints}}"
             class="mi-stat-input mi-stat-input--num" min="0"/>
    </div>
  </div>

  {{! ── WEAPONS ─────────────────────────────────────────────────────────── }}
  <div class="mi-cs-section">
    <div class="mi-section-label">Weapons
      <span class="mi-cs-section-hint mi-muted">— drag weapons here to add</span>
    </div>
    <div class="mi-cs-weapons-drop {{#unless weapons}}mi-cs-weapons-empty{{/unless}}">
      {{#if weapons}}
        {{#each weapons as |w|}}
        <span class="mi-cs-weapon-pill" data-weapon-id="{{w.id}}" title="Click to open weapon sheet">
          {{w.name}}
          <a class="mi-cs-weapon-remove" data-weapon-id="{{w.id}}" title="Remove weapon">
            <i class="fas fa-times"></i>
          </a>
        </span>
        {{/each}}
      {{else}}
        <span class="mi-cs-drop-hint"><i class="fas fa-arrow-down"></i> Drop weapons here</span>
      {{/if}}
    </div>
  </div>

  {{! ── TRAITS ──────────────────────────────────────────────────────────── }}
  <div class="mi-cs-section">
    <div class="mi-section-label">Combat Style Traits
      <span class="mi-cs-section-hint mi-muted">— drag traits from the Traits compendium</span>
    </div>
    <div class="mi-cs-weapons-drop {{#unless traitItems}}mi-cs-weapons-empty{{/unless}}">
      {{#if traitItems}}
        {{#each traitItems as |t|}}
        <span class="mi-cs-weapon-pill mi-cs-trait-pill-item {{#if t.engineEffect}}engine-effect{{/if}}"
              title="{{t.description}}{{#if t.engineEffect}} — affects combat engine{{/if}}">
          {{#if t.engineEffect}}<i class="fas fa-cog mi-cs-trait-icon"></i>{{/if}}
          {{t.name}}
          <a class="mi-cs-trait-remove mi-cs-weapon-remove" data-trait-key="{{t.key}}"
             title="Remove trait">
            <i class="fas fa-times"></i>
          </a>
        </span>
        {{/each}}
      {{else}}
        <span class="mi-cs-drop-hint"><i class="fas fa-arrow-down"></i> Drop combat style traits here</span>
      {{/if}}
    </div>
    <div class="mi-cs-trait-legend mi-muted">
      <i class="fas fa-cog"></i> engine-effect traits modify combat resolution
    </div>
  </div>

  {{! ── EXPERIENCE ──────────────────────────────────────────────────────── }}
  <div class="mi-item-exp-row">
    <label class="mi-exp-label">
      <input type="checkbox" name="system.fumbledLastSession"
             {{#if system.fumbledLastSession}}checked{{/if}}/>
      Fumbled this session <span class="mi-muted">(free +1% on next improvement roll)</span>
    </label>
  </div>

  {{! ── DESCRIPTION ─────────────────────────────────────────────────────── }}
  <div class="mi-item-desc-block">
    <div class="mi-section-label">Description / Notes</div>
    <textarea name="system.description" class="mi-item-desc"
              placeholder="Describe this combat style — its cultural origin, preferred tactics, and when traits apply…">{{system.description}}</textarea>
  </div>

</div>
