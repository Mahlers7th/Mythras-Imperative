<div class="mi-se-roll-dialog">
  <div class="mi-se-roll-header">
    <span class="mi-se-roll-title">Trip Opponent</span>
    <span class="mi-se-roll-subtitle">{{winnerName}} → {{resistingName}}</span>
  </div>
  <div class="mi-se-roll-body">
    <div class="mi-se-roll-row">
      <span class="mi-se-roll-label">{{winnerLabel}} (opposing)</span>
      <span class="mi-se-roll-val">{{attackRoll}}</span>
    </div>
    <div class="mi-se-roll-row mi-se-roll-row--resist">
      <span class="mi-se-roll-label">{{resistingName}} — {{skillName}}{{{condNote}}}</span>
      <span class="mi-se-roll-val">{{skillTotal}}%</span>
    </div>
    <p class="mi-se-roll-note">Roll {{skillName}} to resist being tripped.</p>
  </div>
</div>
