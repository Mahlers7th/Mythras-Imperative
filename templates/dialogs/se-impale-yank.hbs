<div class="mi-se-roll-dialog">
  <div class="mi-se-roll-header">
    <span class="mi-se-roll-title">Impale — Yank Free</span>
    <span class="mi-se-roll-subtitle">{{attackerName}} attempts to withdraw the weapon</span>
  </div>
  <div class="mi-se-roll-body">
    <div class="mi-se-roll-row">
      <span class="mi-se-roll-label">Attacker's skill</span>
      <span class="mi-se-roll-val">{{attackerSkillTotal}}%</span>
    </div>
    <div class="mi-se-roll-row mi-se-roll-row--resist">
      <span class="mi-se-roll-label">{{defenderName}} — Brawn{{{condNote}}}</span>
      <span class="mi-se-roll-val">{{defenderTotal}}%</span>
    </div>
    <p class="mi-se-roll-note">Roll Brawn to hold the weapon in place. Failure means {{attackerName}} yanks it free, causing additional damage.</p>
  </div>
</div>
