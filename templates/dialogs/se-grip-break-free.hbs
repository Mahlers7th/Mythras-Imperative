<div class="mi-se-roll-dialog">
  <div class="mi-se-roll-header">
    <span class="mi-se-roll-title">Break Free from Grip</span>
    <span class="mi-se-roll-subtitle">{{defenderName}} vs {{gripperName}}</span>
  </div>
  <div class="mi-se-roll-body">
    <div class="mi-se-roll-row">
      <span class="mi-se-roll-label">{{gripperName}} — {{gripperSkillName}}</span>
      <span class="mi-se-roll-val">{{gripperSkillTotal}}%</span>
    </div>
    <div class="mi-se-roll-row mi-se-roll-row--resist">
      <span class="mi-se-roll-label">{{defenderName}} — {{skillName}}</span>
      <span class="mi-se-roll-val">{{skillTotal}}%</span>
    </div>
    <p class="mi-se-roll-note">Roll {{skillName}} to break free.</p>
  </div>
</div>
