<div class="mi-se-roll-dialog">
  <div class="mi-se-roll-header">
    <span class="mi-se-roll-title">Disarm Opponent</span>
    <span class="mi-se-roll-subtitle">{{attackerName}} → {{defenderName}}</span>
  </div>
  <div class="mi-se-roll-body">
    <div class="mi-se-roll-row">
      <span class="mi-se-roll-label">Attack roll</span>
      <span class="mi-se-roll-val">{{attackRoll}}</span>
    </div>
    {{#if sizeNote}}
    <div class="mi-se-roll-row mi-se-roll-row--note">
      <span class="mi-se-roll-label">Size modifier</span>
      <span class="mi-se-roll-val mi-se-roll-val--note">{{sizeNote}}</span>
    </div>
    {{/if}}
    <div class="mi-se-roll-row mi-se-roll-row--resist">
      <span class="mi-se-roll-label">{{defenderName}} — {{defenderSkill}}{{{condNote}}}</span>
      <span class="mi-se-roll-val">{{defenderTotal}}%</span>
    </div>
    <p class="mi-se-roll-note">Roll Combat Style to resist the disarm. Failure means the weapon is knocked free.</p>
  </div>
</div>
