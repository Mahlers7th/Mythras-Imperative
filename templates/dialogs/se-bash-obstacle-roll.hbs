<div class="mi-se-roll-dialog">
  <div class="mi-se-roll-header">
    <span class="mi-se-roll-title">Bash — Obstacle Collision</span>
    <span class="mi-se-roll-subtitle">{{defenderName}}</span>
  </div>
  <div class="mi-se-roll-body">
    <div class="mi-se-roll-row mi-se-roll-row--resist">
      <span class="mi-se-roll-label">{{defenderName}} — {{skillName}} (Hard: {{skillTotal}}%)</span>
      <span class="mi-se-roll-val">{{skillTotal}}%</span>
    </div>
    <p class="mi-se-roll-note">Roll to avoid being knocked Prone. Failure means {{defenderName}} trips over the obstacle.</p>
  </div>
</div>
